# --- eBay Browse API (free OAuth Client Credentials) ---
# Create an app at https://developer.ebay.com (free).
# Copy the "App ID (Client ID)" and "Cert ID (Client Secret)" from the
# Production keyset into the values below. The Browse API is free for
# basic search and returns currently active listings.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Optional: switch to "sandbox" while testing. Default is production.
EBAY_ENV=production

# --- PriceCharting (paid, optional) ---
# If set, card detail pages will fetch live grade prices.
PRICECHARTING_TOKEN=
